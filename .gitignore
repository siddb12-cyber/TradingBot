# =========================
# TRADINGBOT .gitignore
# =========================

# --- Secrets — NEVER commit ---
.env

# --- Python cache ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# --- Trade data (local only — per-day runtime files) ---
trade_logs/
trade_logs_archive/
screenshots/
temp/
data/
decisions/
trades/

# --- Runtime logs (local only) ---
logs/
*.log

# --- Debug artifacts ---
cropped_debug.png
*.xlsx
*.csv

# --- IDE ---
.vscode/
.idea/
*.suo
*.user

# --- Windows ---
Thumbs.db
Desktop.ini
runtime/heartbeats/

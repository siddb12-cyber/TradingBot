# =========================
# TRADINGBOT ENVIRONMENT CONFIG — TEMPLATE
# Copy to .env and fill in your real values.
# This file is safe to commit. .env is NOT.
# =========================

# --- Telegram Bot ---
# Get from @BotFather on Telegram
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
CHAT_ID=YOUR_TELEGRAM_CHAT_ID_HERE

# --- Chrome Remote Debugging ---
# Must match the --remote-debugging-port you launch Chrome with
CHROME_DEBUG_URL=http://127.0.0.1:9222

# --- Tesseract OCR ---
# Full path to tesseract.exe on your machine
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
